void guessgamef()
{
	FILE *fp;
	int num,f=1,trys=0,ges,tp,op;
	char end;
	clrscr();
	fp=fopen("c:\\31\\rannum.txt","r");
	fscanf(fp,"%d",&num);
	fclose(fp);
	printf("\n1.for easy\n2.for nightmare");
	printf("\nEnter difficulty:");
	scanf("%d",&op);
	switch(op)
	{
		case 2:
			while(f==1)
			{
				printf("Enter num to guess:");
				scanf("%d",&ges);
				trys++;
				if(num==ges)
				{
					f=0;
				}
			}
			break;
		case 1:
			printf("Enter num to guess:");
			scanf("%d",&ges);
			trys++;
			while(f==1)
				{
					if(num==ges)
					{
						f=0;
					}
					else if(ges>num)
					{
						printf("try small:");
						scanf("%d",&ges);
						trys++;
					}
					else
					{
						printf("try big:");
						scanf("%d",&ges);
						trys++;
					}
				}
			break;

	}
	printf("\nyou guessed num in %d tryes",trys);
	if(((num/trys)+num)>1000)
	{
		tp=((num/trys)-num)+1;
	}
	else
	{
		tp=((num/trys)+num)+1;
	}
	fp=fopen("c:\\31\\rannum.txt","w");
	fprintf(fp,"%d",tp);
	fclose(fp);
	printf("\nenter 0.");
	scanf("\n%d",&end);
	return;
}
